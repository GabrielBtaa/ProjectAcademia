# Supabase → Project Settings → Database
# Copie a URI em "Connection string" e substitua [YOUR-PASSWORD] pela senha do BANCO (não é a senha do login do site).
#
# Recomendado para Node/Prisma: modo "Direct" / host db.xxxxx.supabase.co / porta 5432
# No final da URL, use SSL explícito:
DATABASE_URL="postgresql://postgres:[GB283125!02]@db.mslckkorswguxptixtne.supabase.co:5432/postgres?sslmode=require"
#
# Senha com caracteres especiais (@ # : etc.) → codifique na URL (ex.: @ → %40)
#
# Se você usar Transaction pooler (porta 6543), acrescente também: &pgbouncer=true
# e para migrações o Prisma costuma precisar de uma URL "direta" separada — prefira Direct 5432 até funcionar.

# Opcional em produção: origem do front (separar por vírgula se tiver mais de um)
# FRONTEND_ORIGIN=https://seu-app.vercel.app

PORT=3001
